{
  "name": "@nnrp/native-server",
  "version": "1.0.0-preview.3.4",
  "description": "Node.js and Deno native server SDK for NNRP.",
  "keywords": [
    "nnrp",
    "ai",
    "runtime",
    "server",
    "native",
    "typescript"
  ],
  "type": "module",
  "private": true,
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NagareWorks/nnrp-js.git",
    "directory": "packages/native-server"
  },
  "bugs": {
    "url": "https://github.com/NagareWorks/nnrp-js/issues"
  },
  "homepage": "https://github.com/NagareWorks/nnrp-js/tree/main/packages/native-server#readme",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
