{
  "name": "@nnrp/native",
  "version": "1.0.0-preview.3",
  "description": "Node.js native artifact loading primitives for NNRP.",
  "type": "module",
  "private": true,
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NagareWorks/nnrp-js.git",
    "directory": "packages/native"
  },
  "bugs": {
    "url": "https://github.com/NagareWorks/nnrp-js/issues"
  },
  "homepage": "https://github.com/NagareWorks/nnrp-js/tree/main/packages/native#readme",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./experimental/*": null,
    "./internal/*": null
  },
  "files": [
    "README.md",
    "dist/index.js",
    "dist/index.d.ts",
    "dist/index.d.ts.map"
  ],
  "nnrp": {
    "nativeArtifacts": {
      "enabled": false
    }
  },
  "dependencies": {
    "@nnrp/core": "workspace:*"
  }
}
