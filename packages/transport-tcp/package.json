{
  "name": "@nnrp/transport-tcp",
  "version": "1.0.0-preview.3.3",
  "description": "TCP transport adapter with native and WASM artifacts for NNRP runtimes.",
  "keywords": [
    "nnrp",
    "ai",
    "runtime",
    "transport",
    "tcp",
    "typescript"
  ],
  "type": "module",
  "private": true,
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NagareWorks/nnrp-js.git",
    "directory": "packages/transport-tcp"
  },
  "bugs": {
    "url": "https://github.com/NagareWorks/nnrp-js/issues"
  },
  "homepage": "https://github.com/NagareWorks/nnrp-js/tree/main/packages/transport-tcp#readme",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./experimental/*": null,
    "./internal/*": null
  },
  "files": [
    "README.md",
    "dist/index.js",
    "dist/index.d.ts",
    "dist/index.d.ts.map",
    "native/**",
    "wasm/**"
  ],
  "dependencies": {
    "@nnrp/core": "workspace:*"
  },
  "nnrp": {
    "transport": "tcp",
    "nativeArtifacts": {
      "enabled": true
    },
    "wasmArtifacts": {
      "enabled": true
    }
  }
}
